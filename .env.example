# ============================================================
# Variables de entorno del FRONTEND (Vite)
# ============================================================
# Copia este fichero como .env.local y rellena los valores.
# NUNCA comitas .env.local ni .env al repositorio.
#
# Dónde encontrar estos valores:
#   Supabase Dashboard → Project Settings → API
# ============================================================

# URL pública del proyecto Supabase
VITE_SUPABASE_URL=https://<tu-project-ref>.supabase.co

# Clave anon (segura de exponer en el cliente; RLS la protege)
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# Clave pública VAPID para Web Push (se genera con el CLI de web-push)
# Genera las claves con: node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
# La clave PÚBLICA va aquí; la PRIVADA va como secret en Supabase (VAPID_PRIVATE_KEY)
VITE_VAPID_PUBLIC_KEY=
