# ============================================================
# Secrets del BACKEND (Supabase Edge Functions)
# ============================================================
# Configúralos con el CLI:
#   supabase secrets set NOMBRE=valor
# O en Dashboard → Project Settings → Edge Functions → Secrets
#
# NUNCA pongas valores reales en este fichero.
# ============================================================

# ── Datos de fútbol: API-Football (api-sports.io) ────────────
# Clave de acceso. Header: x-apisports-key
# Alta gratuita en https://dashboard.api-football.com/
APISPORTS_KEY=<tu-api-key>

# ID de la competición "World Cup" en API-Football.
# Se auto-descubre en el primer import-fixtures si no está configurado;
# guarda el valor que muestre el log para evitar la llamada extra.
# Ejemplo: World Cup = 1 (verificar en el log de import-fixtures).
WC_LEAGUE_ID=<league-id>

# Temporada del Mundial
WC_SEASON=2026

# ── Web Push (VAPID) ─────────────────────────────────────────
# Genera con: npx web-push generate-vapid-keys
# La pública va también en .env.local del frontend (VITE_VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=<clave-publica-base64url>
VAPID_PRIVATE_KEY=<clave-privada-base64url>
VAPID_SUBJECT=mailto:<tu-email>

# ── Gemini (Google AI Studio) ─────────────────────────────────
# Para comic-gen (viñeta de grupo) y daily-roast (crónica diaria)
GEMINI_API_KEY=<tu-gemini-key>

# ── (Opcional, Fase 9) Resend — email de respaldo ────────────
# RESEND_API_KEY=<tu-resend-key>
