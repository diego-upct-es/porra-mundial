# ============================================================
# Secrets del BACKEND (Supabase Edge Functions)
# ============================================================
# Configúralos con el CLI:
#   supabase secrets set NOMBRE=valor
# O en Dashboard → Project Settings → Edge Functions → Secrets
#
# NUNCA pongas valores reales en este fichero.
# ============================================================

# API-Football (api-sports.io) — clave de acceso a fixtures/resultados/stats
API_FOOTBALL_KEY=<tu-api-key>

# ID de la competición FIFA World Cup en API-Football
# (se obtiene con GET /leagues?search=world cup y se confirma manualmente)
WC_LEAGUE_ID=<league-id>

# Temporada del Mundial (p.ej. 2026)
WC_SEASON=2026

# Claves VAPID para Web Push (se generan con: npx web-push generate-vapid-keys)
# La pública va también en .env.local del frontend (VITE_VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=<clave-publica>
VAPID_PRIVATE_KEY=<clave-privada>
VAPID_SUBJECT=mailto:<tu-email>

# (Opcional, Fase 9) Resend — email de respaldo
# RESEND_API_KEY=<tu-resend-key>
